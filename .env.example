# TTS Provider Credentials

# iFlytek (科大讯飞)
# You can get these from https://console.xfyun.cn/services/tts
IFLYTEK_APP_ID=
IFLYTEK_API_KEY=
IFLYTEK_API_SECRET=

# Baidu (百度语音)
# You can get these from https://console.bce.baidu.com/ai/#/ai/speech/overview/index
BAIDU_APP_ID=
BAIDU_API_KEY=
BAIDU_API_SECRET=

# ElevenLabs
# You can get this from https://elevenlabs.io/dashboard/api-keys
ELEVENLABS_API_KEY=

# Application Settings
# Path to store audio files
STORAGE_PATH=/path/to/audiobooks
